  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": [ "{{baseUrl}}" ], "path": [ "api", "auth", "register" ] },
            "body": { "mode": "raw", "raw": "{\n    \"email\": \"student1@test.com\",\n    \"password\": \"password123\",\n    \"role\": \"student\"\n}" }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": [ "{{baseUrl}}" ], "path": [ "api", "auth", "login" ] },
            "body": { "mode": "raw", "raw": "{\n    \"email\": \"student1@test.com\",\n    \"password\": \"password123\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Subjects",
      "item": [
        {
          "name": "Create Subject (Faculty)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "{{token}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/subjects", "host": [ "{{baseUrl}}" ], "path": [ "api", "subjects" ] },
            "body": { "mode": "raw", "raw": "{\n    \"name\": \"Data Structures\",\n    \"code\": \"CS301\"\n}" }
          }
        },
        {
          "name": "Get Subjects",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "{{token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/subjects", "host": [ "{{baseUrl}}" ], "path": [ "api", "subjects" ] }
          }
        }
      ]
    },
    {
      "name": "Enrollments",
      "item": [
        {
          "name": "Enroll Student",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "{{token}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/enrollments", "host": [ "{{baseUrl}}" ], "path": [ "api", "enrollments" ] },
            "body": { "mode": "raw", "raw": "{\n    \"subjectId\": 1,\n    \"studentId\": 2\n}" }
          }
