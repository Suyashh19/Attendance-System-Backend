          }
        }
      ]
    },
    {
      "name": "Sessions",
      "item": [
        {
          "name": "Start Session (Faculty)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "{{token}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/sessions/start", "host": [ "{{baseUrl}}" ], "path": [ "api", "sessions", "start" ] },
            "body": { "mode": "raw", "raw": "{\n    \"subjectId\": 1,\n    \"latitude\": 12.9715987,\n    \"longitude\": 77.5945627\n}" }
          }
        },
        {
          "name": "End Session (Faculty)",
          "request": {
            "method": "POST",
