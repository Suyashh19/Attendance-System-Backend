    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "Submit Attendance (Student)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "{{token}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/attendance/submit", "host": [ "{{baseUrl}}" ], "path": [ "api", "attendance", "submit" ] },
            "body": { "mode": "raw", "raw": "{\n    \"sessionId\": 1,\n    \"selectedCode\": \"472\",\n    \"deviceId\": \"A1B2C3D4\",\n    \"latitude\": 12.9715,\n    \"longitude\": 77.5946\n}" }
