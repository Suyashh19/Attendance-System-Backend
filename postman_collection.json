          }
        },
        {
          "name": "Get My Record (Student)",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "{{token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/attendance/subject/1/my-record", "host": [ "{{baseUrl}}" ], "path": [ "api", "attendance", "subject", "1", "my-record" ] }
